## .lgo generated by admixtools::graph_to_lgo()

### Parameters
time fixed T_out=0
time fixed T_arch=0
time fixed T_afr=0
time fixed T_eur=0
time free T_R=3
time free T_anc=2
time free T_arch_anc=1
time free T_hum_anc=1
time free T_admix_eur=1
twoN fixed one=1
mixFrac free m_eur=0.03

### Segments
segment R t=T_R twoN=one
segment anc t=T_anc twoN=one
segment arch_anc t=T_arch_anc twoN=one
segment hum_anc t=T_hum_anc twoN=one
segment out t=T_out twoN=one samples=1
segment arch t=T_arch twoN=one samples=1
segment afr t=T_afr twoN=one samples=1
segment eur t=T_eur twoN=one samples=1
segment eur_hum_anc t=T_admix_eur twoN=one
segment eur_arch_anc t=T_admix_eur twoN=one

### Relationships
derive out from R
derive anc from R
derive arch_anc from anc
derive hum_anc from anc
derive arch from arch_anc
derive afr from hum_anc
derive eur_hum_anc from hum_anc
derive eur_arch_anc from arch_anc
mix eur from eur_hum_anc + m_eur * eur_arch_anc
