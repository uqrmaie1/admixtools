## .lgo generated by admixtools::graph_to_lgo()

### Parameters
time fixed T_X=0
time free T_R=0.07
time free T_A=0.02
time free T_B=0.02
time free T_M=0.02
time free T_admix_M=0.02
twoN free twoN_R=10000
twoN free twoN_A=5000
twoN free twoN_B=5000
twoN free twoN_M=5000
twoN free twoN_X=1000
mixFrac free m_M=0.4

### Segments
segment R t=T_R twoN=twoN_R
segment A t=T_A twoN=twoN_A
segment B t=T_B twoN=twoN_B
segment M t=T_M twoN=twoN_M
segment X t=T_X twoN=twoN_X samples=1
segment M_A t=T_admix_M twoN=twoN_A
segment M_B t=T_admix_M twoN=twoN_B

### Relationships
derive A from R
derive B from R
derive X from M
derive M_A from A
derive M_B from B
mix M from M_A + m_M * M_B
