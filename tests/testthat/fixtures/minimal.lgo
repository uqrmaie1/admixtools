## .lgo generated by admixtools::graph_to_lgo()

### Parameters
time fixed T_X=0
time free T_R=0.07
time free T_A=0.02
time free T_B=0.02
time free T_M=0.02
time free T_admix_M=0.02
twoN fixed one=1
mixFrac free m_M=0.4

### Segments
segment R t=T_R twoN=one
segment A t=T_A twoN=one
segment B t=T_B twoN=one
segment M t=T_M twoN=one
segment X t=T_X twoN=one samples=1
segment M_A t=T_admix_M twoN=one
segment M_B t=T_admix_M twoN=one

### Relationships
derive A from R
derive B from R
derive X from M
derive M_A from A
derive M_B from B
mix M from M_A + m_M * M_B
